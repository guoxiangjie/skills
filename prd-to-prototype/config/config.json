{
  "name": "prd-to-prototype",
  "version": "2.0.0",
  "description": "将PRD文档转换为可交互原型网页",
  "author": "PRD Template",
  "dependencies": {
    "frontend-design": {
      "required": true,
      "purpose": "获取页面风格和主题色",
      "installHint": "使用 npx skills add 命令安装 frontend-design skill"
    }
  },
  "commands": {
    "default": "generate",
    "list": [
      {
        "name": "generate",
        "description": "根据PRD文档生成可交互原型网页",
        "path": "commands/generate.md"
      },
      {
        "name": "preview",
        "description": "预览已生成的原型网页",
        "path": "commands/preview.md"
      }
    ]
  },
  "templates": {
    "prototypePrompt": "templates/prototype_prompt_template.md",
    "viteTemplate": "templates/vite_template.md",
    "pageTemplate": "templates/page_template.md",
    "componentTemplate": "templates/component_template.md"
  },
  "techStack": {
    "build": "Vite",
    "framework": "React 18",
    "uiFramework": {
      "web": "Ant Design 5.x",
      "mobile": "Ant Design Mobile 5.x"
    },
    "charts": "Ant Design Charts",
    "icons": "lucide-react",
    "router": "React Router 6"
  },
  "output": {
    "directory": "prototype",
    "structure": {
      "src": {
        "components": "通用组件",
        "pages": "页面组件",
        "layouts": "布局组件",
        "router": "路由配置",
        "styles": "样式文件",
        "utils": "工具函数"
      }
    }
  },
  "variables": {
    "PROJECT_NAME": {
      "source": "main_prd",
      "section": "文档基础信息",
      "field": "项目名称"
    },
    "BACKGROUND": {
      "source": "main_prd",
      "section": "项目背景与目标",
      "field": "背景说明"
    },
    "OBJECTIVES": {
      "source": "main_prd",
      "section": "项目背景与目标",
      "field": "产品目标"
    },
    "USER_ROLES": {
      "source": "main_prd",
      "section": "用户故事概述",
      "field": "用户角色与权限"
    },
    "MODULES": {
      "source": "main_prd",
      "section": "功能模块清单",
      "field": "模块列表"
    },
    "PRIMARY_COLOR": {
      "source": "frontend-design",
      "field": "主题色"
    },
    "DESIGN_STYLE": {
      "source": "frontend-design",
      "field": "设计风格"
    }
  },
  "prdPatterns": {
    "mainPrd": "*_main_prd.md",
    "modulePrd": "*_module_prd.md"
  },
  "server": {
    "defaultPort": 3000,
    "portRange": [3000, 3010],
    "host": "localhost"
  },
  "progressSteps": [
    {
      "step": 1,
      "name": "依赖检测",
      "description": "检查 frontend-design skill 是否可用"
    },
    {
      "step": 2,
      "name": "平台选择",
      "description": "让用户选择目标平台"
    },
    {
      "step": 3,
      "name": "扫描 PRD 文件",
      "description": "查找项目中的所有 PRD 文件"
    },
    {
      "step": 4,
      "name": "解析 PRD 内容",
      "description": "提取项目信息和模块清单"
    },
    {
      "step": 5,
      "name": "获取设计规范",
      "description": "调用 frontend-design skill 获取页面风格和主题色"
    },
    {
      "step": 6,
      "name": "初始化项目",
      "description": "使用 Vite 创建 React 项目"
    },
    {
      "step": 7,
      "name": "生成页面组件",
      "description": "为每个页面生成 React 组件"
    },
    {
      "step": 8,
      "name": "生成通用组件",
      "description": "生成表单、列表、图表组件"
    },
    {
      "step": 9,
      "name": "完善项目配置",
      "description": "配置路由、主题、样式"
    }
  ]
}
